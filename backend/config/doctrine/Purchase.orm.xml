<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Domain\Entity\Purchase" table="purchases">
        <id name="id" type="string" length="36">
            <generator strategy="NONE"/>
        </id>

        <many-to-one field="user" target-entity="App\Domain\Entity\User">
            <join-column name="user_id" referenced-column-name="id" nullable="false"/>
        </many-to-one>

        <many-to-one field="event" target-entity="App\Domain\Entity\Event">
            <join-column name="event_id" referenced-column-name="id" nullable="false"/>
        </many-to-one>

        <field name="quantity"   type="integer"/>
        <field name="totalPrice" type="float"/>
        <field name="status"     type="string" length="20"/>
        <field name="purchasedAt" type="datetime_immutable"/>

        <one-to-many field="tickets"
                     target-entity="App\Domain\Entity\Ticket"
                     mapped-by="purchase">
            <cascade>
                <cascade-persist/>
            </cascade>
        </one-to-many>
    </entity>

</doctrine-mapping>
